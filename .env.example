# ─────────────────────────────────────────────────────────────
# AgriConnect — Environment variables
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# For Vercel: add each of these in
#   Project → Settings → Environment Variables
# (Production, Preview, Development — usually all three)
#
# All variables MUST start with VITE_ to be exposed to the
# Vite client bundle.
# ─────────────────────────────────────────────────────────────

# ── Firebase (used for Phone OTP authentication) ──
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxx

# ── Supabase (backend / database) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Google Gemini (AI advisory) ──
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_GEMINI_MODEL=gemini-2.5-flash

# ── OpenWeather (weather forecasts) ──
VITE_OPENWEATHER_API_KEY=your-openweather-api-key

# ── data.gov.in (Mandi prices) ──
VITE_DATA_GOV_API_KEY=your-data-gov-api-key

# ── OpenStreetMap tiles ──
VITE_OSM_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ── App config ──
VITE_APP_NAME=AgriConnect
VITE_DEFAULT_LANGUAGE=en
